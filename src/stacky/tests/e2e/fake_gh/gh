#!/usr/bin/env python3
"""Fake `gh` binary for stacky e2e tests.

Only handles `gh auth status` (so stacky's init_git() passes). Any other
subcommand fails loudly so tests that accidentally reach GitHub surface as
errors rather than silent no-ops.
"""
import sys

args = sys.argv[1:]
if args[:2] == ["auth", "status"]:
    sys.exit(0)

sys.stderr.write(f"fake_gh: unsupported subcommand: {args}\n")
sys.exit(2)
